# =========================
# Entorno Virtual Python
# =========================
# Ignorar el directorio del entorno virtual
venv/
.venv/
env/
.env

# =========================
# Archivos de caché y compilados
# =========================
# Cachés de Python
__pycache__/
*.pyc
# Archivos de caché de pytest
.pytest_cache/
# Archivos específicos de PyCharm o VSCode
.idea/
.vscode/

# =========================
# Archivos de Datos Generados
# CRÍTICO: No subir datasets grandes, logs ni el input XML/JSON
# =========================
data/*.csv
data/*.json
data/*.log
data/*.xml

# Archivos de respaldo temporales creados por los tests
*_TEST_BACKUP

# =========================
# Logs y Artefactos del Modelo
# =========================
# Logs de ejecución (incluyendo recommender.log)
*.log
# Modelos de ML entrenados (si se guardan)
src/model/*.pkl
src/model/*.h5
src/model/*.joblib

# =========================
# Frontend Build Files
# =========================
# Ignorar dependencias, builds y archivos temporales del frontend
/frontend/build/
/frontend/node_modules/
/frontend/.dart_tool/
/frontend/.flutter-plugins
/frontend/.flutter-plugins-dependencies
/frontend/.idea/
/frontend/.vscode/
/frontend/.metadata
/frontend/pubspec.lock
/frontend/(nombre_del_proyecto).iml
/frontend/.DS_Store